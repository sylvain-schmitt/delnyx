{% if googleReviews.reviews is defined and googleReviews.reviews|length > 0 %}
	<section class="py-24 relative section-transition" id="google-reviews">
		<style>
			#google-reviews .star-fill path {
				fill: currentColor;
			}
		</style>
		{# Wrapper overflow-hidden uniquement pour les backgrounds absolus (évite de clipper les cards au hover) #}
		<div class="absolute inset-0 overflow-hidden">
			{# Background harmonisé avec les autres sections #}
			<div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-700 to-slate-800"></div>

			{# Background avec effet de transition fluide depuis la section précédente #}
			<div class="absolute inset-0 bg-gradient-to-br from-slate-800 via-slate-900 to-slate-700"></div>

			{# Lumière bleue - responsive (z-0 pour être DERRIÈRE les cartes) #}
			<div class="absolute top-1/4 left-[2%] w-[150px] h-[150px] sm:w-[300px] sm:h-[300px] sm:left-[3%] rounded-full light-ambient" style="background: radial-gradient(circle, rgba(59,130,246,0.25) 0%, transparent 70%);"></div>

			{# Lumière violette - responsive (z-0 pour être DERRIÈRE les cartes) #}
			<div class="absolute bottom-[20%] right-[2%] w-[120px] h-[120px] sm:w-[200px] sm:h-[200px] sm:right-[5%] rounded-full light-ambient" style="background: radial-gradient(circle, rgba(139, 92, 246, 0.25) 0%, transparent 70%);"></div>
		</div>

		<div class="container mx-auto px-4 relative z-10">
			<div class="max-w-4xl mx-auto text-center mb-16 px-4">
				<h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-16 lg:mb-20">
					Ce qu'ils disent de
					<span class="bg-gradient-to-r from-blue-400 via-cyan-400 to-purple-500 bg-clip-text text-transparent">Delnyx</span>
				</h2>
				<div class="flex flex-col items-center justify-center gap-10">
					<div class="flex items-center gap-6 px-10 py-6 rounded-3xl bg-white/5 border border-white/10 backdrop-blur-md shadow-xl">
						<span class="text-5xl lg:text-6xl font-black text-white glow-text">{{ (googleReviews.rating == 5) ? '5.0' : (googleReviews.rating|number_format(1, '.', '.')) }}</span>
						<div class="flex flex-col items-start border-l border-white/10 pl-6">
							<div class="flex text-amber-400 mb-1 gap-1">
								{% for i in 1..5 %}
									{% if i <= googleReviews.rating %}
										{{ ux_icon('lucide:star', {class: 'w-7 h-7 star-fill'}) }}
									{% elseif i - 0.5 <= googleReviews.rating %}
										{{ ux_icon('lucide:star-half', {class: 'w-7 h-7 star-fill'}) }}
									{% else %}
										{{ ux_icon('lucide:star', {class: 'w-7 h-7 text-slate-700/50'}) }}
									{% endif %}
								{% endfor %}
							</div>
							<p class="text-slate-300 text-sm font-medium opacity-80 italic">Basé sur
								{{ googleReviews.total_ratings }}
								avis Google Business</p>
						</div>
					</div>

					{% if companySettings is defined and companySettings and companySettings.googlePlaceId %}
						<a href="https://www.google.com/maps/place/?q=place_id:{{ companySettings.googlePlaceId }}" target="_blank" class="flex items-center gap-3 px-10 py-4 rounded-xl bg-blue-500/10 border border-blue-400/20 text-blue-400 hover:bg-blue-500/20 transition-all duration-300 font-bold group shadow-lg">
							Voir sur Google Maps
							{{ ux_icon('lucide:external-link', {class: 'w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300'}) }}
						</a>
					{% endif %}
				</div>
			</div>

			<div
				data-controller="reviews-carousel" data-action="mouseenter->reviews-carousel#pause mouseleave->reviews-carousel#resume" class="relative" style="overflow-x: clip;">
				{# overflow-x:clip sur le wrapper (pas de scroll container) = overflow-y reste visible, pas de clip sur les cards au hover #}
				<div data-reviews-carousel-target="track" class="flex gap-8 will-change-transform">
					{% for review in googleReviews.reviews %}
						<div class="flex-none w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.334rem)] group relative h-auto">
							<div
								class="glass-card optimized-blur flex flex-col items-start h-full">
								{# Header de l'avis #}
								<div class="flex items-center gap-4 mb-6">
									{% if review.profile_photo_url is defined and review.profile_photo_url %}
										<img src="{{ review.profile_photo_url }}" alt="{{ review.author_name }}" class="w-12 h-12 rounded-full border border-white/10 ring-2 ring-blue-500/20 object-cover shadow-md" loading="lazy">
									{% else %}
										<div class="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center border border-white/10 text-blue-400 font-bold">
											{{ review.author_name|first|upper }}
										</div>
									{% endif %}
									<div>
										<h4 class="text-white font-bold text-lg leading-tight">{{ review.author_name }}</h4>
										<span class="text-slate-500 text-xs">{{ review.relative_time_description }}</span>
									</div>
								</div>

								{# Étoiles #}
								<div class="flex text-amber-500 mb-5 gap-1">
									{% for i in 1..5 %}
										{% if i <= review.rating %}
											{{ ux_icon('lucide:star', {class: 'w-5 h-5 star-fill'}) }}
										{% else %}
											{{ ux_icon('lucide:star', {class: 'w-5 h-5 text-slate-700/50'}) }}
										{% endif %}
									{% endfor %}
								</div>

								{# Texte #}
								<p class="text-gray-300 leading-relaxed italic mb-8 relative">
									"{{ review.text|length > 200 ? review.text|slice(0, 197) ~ '...' : review.text }}"
								</p>

								<div class="mt-auto flex items-center gap-2 text-sm text-emerald-500 font-semibold opacity-90">
									{{ ux_icon('lucide:check-circle', {class: 'w-5 h-5'}) }}
									Avis vérifié Google
								</div>
							</div>
						</div>
					{% endfor %}
				</div>

				{# Indicateur de swipe #}
				<div class="flex justify-center gap-2 mt-4 opacity-30 md:hidden">
					<div class="w-12 h-1 bg-white/20 rounded-full overflow-hidden">
						<div class="w-1/3 h-full bg-blue-500 rounded-full"></div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endif %}
